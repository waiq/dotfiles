#!/bin/bash

set -e

# Default variable values
verbose_mode=false

if ! [ -x "$(command -v ansible)" ]; then
  echo "ansible not found"
  exit 1;
fi

if ! [ -x "$(command -v ansible-playbook)" ]; then
  echo "ansible-playbook not found"
  exit 1;
fi

# Function to display script usage
usage() {
 echo "Usage: $0 [OPTIONS]"
 echo "Options:"
 echo " -h, --help       Display this help message"
 echo " -v, --verbose    Enable verbose mode"
 echo " -r, --roles      List roles"
 echo " -t, --tags       List tags"
 echo " --tasks          List tasks"
}

ansible_playbook_command="ansible-playbook -i {{ core.files.inventory }}"

run_roles() {
  echo "$@"
}
run_tags() {
  echo "not implimented"
}

run_tasks() {
  echo "not implimented"
}

# Function to handle options and arguments
handle_options() {
  while [ $# -gt 0 ]; do
    case $1 in
      -h | --help)
        usage
        exit 0
        ;;
      -v | --verbose)
        verbose_mode=true
        ;;
      -r | --roles)
        shift
        run_roles "${@}"
        exit 0
        ;;
      -t | --tags)
        run_tags "${0}"
        exit 0
        ;;
      --tasks)
        run_tasks "${0}"
        exit 0
        ;;
      *)
        echo "Invalid option: $1" >&2
        usage
        exit 1
        ;;
    esac
    shift
  done
  usage
}

# Main script execution
handle_options "${@}"
