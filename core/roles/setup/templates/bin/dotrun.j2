#!/bin/bash

set -e

# Default variable values
verbose_mode=false

if ! [ -x "$(command -v ansible)" ]; then
  echo "ansible not found"
  exit 1;
fi

if ! [ -x "$(command -v ansible-playbook)" ]; then
  echo "ansible-playbook not found"
  exit 1;
fi

# Function to display script usage
usage() {
 echo "Usage: $0 [OPTIONS]"
 echo "Options:"
 echo " -h, --help       Display this help message"
 echo " -v, --verbose    Enable verbose mode"
 echo " -u, --update     Update/regenerate tags"
 echo " -r, --roles      run roles"
 echo " -t, --tags       run tags"
 echo " --tasks          run tasks"
}

run_roles() {
  eval "ansible-playbook -i {{ core.files.inventory }} {{ core.files.generated.tags }} --ask-become-pass -t ${@}" 
  return $?
}

run_update() {
  eval "ansible-playbook -i {{ core.files.inventory }} {{ core.files.roles }} -t update-tags" 
  return $?
}

run_tags() {
  echo "not implemented"
  return 1
}

run_tasks() {
  echo "not implemented"
  return 1
}

# Function to handle options and arguments
handle_options() {
  while [ $# -gt 0 ]; do
    case $1 in
      -h | --help)
        usage
        return 0
        ;;
      -v | --verbose)
        verbose_mode=true
        ;;
	  -u | --update)
        shift
		run_update "${@}"
		return $?
		;;
      -r | --roles)
        shift
        run_roles "${@}"
		return $?
        ;;
      -t | --tags)
        run_tags "${0}"
		return $?
        ;;
      --tasks)
        run_tasks "${0}"
		return $?
        ;;
      *)
        echo "Invalid option: $1" >&2
        usage
        return 1
        ;;
    esac
    shift
  done
  usage
}

# Main script execution
handle_options "${@}"
local retvalue=$?

if [ $retvalue -ne 0 ]; then
  exit $?
fi

source {{ core.files.init }}



