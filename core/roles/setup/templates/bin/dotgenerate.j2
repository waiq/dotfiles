#!/bin/bash

set -e

# Function to handle options and arguments
handle_options() {
  while [ $# -gt 0 ]; do
    case $1 in
      -h | --help)
        usage
        exit 0
        ;;
      -v | --verbose)
        verbose_mode=true
        ;;
      -r | --roles)
        shift
        run_roles "${@}"
        exit 0
        ;;
      -t | --tags)
        run_tags "${0}"
        exit 0
        ;;
      --tasks)
        run_tasks "${0}"
        exit 0
        ;;
      *)
        echo "Invalid option: $1" >&2
        usage
        exit 1
        ;;
    esac
    shift
  done
  usage
}

# Main script execution
handle_options "${@}"

