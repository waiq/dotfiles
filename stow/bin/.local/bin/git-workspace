#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  git-workspace [OPTIONS] <name>

Create a new git branch and worktree from a name.

Options:
  -b, --base <branch>        Base branch to branch from (default: main)
  -r, --root <dir>           Workspaces root directory
                             (default: ../workspaces/<repo-name>)
  -f, --force                Reuse existing branch name if branch exists
  -h, --help                 Show this help

Environment:
  GIT_WORKSPACE_ROOT         Overrides default workspaces root

Naming:
  branch:                    <repo-name>/<slug>
  workspace dir:             <repo-name>-<slug>
EOF
}

die() {
  echo "git-workspace: $*" >&2
  exit 1
}

slugify() {
  local input="$1"
  local out
  out="$(printf '%s' "$input" | tr '[:upper:]' '[:lower:]')"
  out="$(printf '%s' "$out" | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
  [ -n "$out" ] || die "name resolves to empty slug"
  printf '%s\n' "$out"
}

base_branch="main"
workspace_root="${GIT_WORKSPACE_ROOT:-}"
force_reuse_branch=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    -b|--base)
      [ "$#" -ge 2 ] || die "missing value for $1"
      base_branch="$2"
      shift 2
      ;;
    -r|--root)
      [ "$#" -ge 2 ] || die "missing value for $1"
      workspace_root="$2"
      shift 2
      ;;
    -f|--force)
      force_reuse_branch=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

[ "$#" -eq 1 ] || {
  usage
  exit 1
}

input_name="$1"

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git repository"

repo_root="$(git rev-parse --show-toplevel)"
repo_name="$(basename "$repo_root")"
slug="$(slugify "$input_name")"
branch_name="${repo_name}/${slug}"

if ! git show-ref --verify --quiet "refs/heads/$base_branch"; then
  if [ "$base_branch" = "main" ] && git show-ref --verify --quiet "refs/heads/master"; then
    base_branch="master"
  else
    die "base branch '$base_branch' not found"
  fi
fi

if [ -z "$workspace_root" ]; then
  workspace_root="$repo_root/../workspaces/$repo_name"
fi

workspace_root="$(cd "$(dirname "$workspace_root")" && pwd)/$(basename "$workspace_root")"
workspace_dir_name="${repo_name}-${slug}"
workspace_path="$workspace_root/$workspace_dir_name"

[ -e "$workspace_path" ] && die "workspace path already exists: $workspace_path"

mkdir -p "$workspace_root"

if git show-ref --verify --quiet "refs/heads/$branch_name"; then
  if [ "$force_reuse_branch" -eq 1 ]; then
    git worktree add "$workspace_path" "$branch_name"
    echo "Project: $repo_name"
    echo "Workspace root: $workspace_root"
    echo "Created workspace: $workspace_path"
    echo "Using existing branch: $branch_name"
    exit 0
  fi
  die "branch already exists: $branch_name (use --force to reuse)"
fi

git worktree add -b "$branch_name" "$workspace_path" "$base_branch"
echo "Project: $repo_name"
echo "Workspace root: $workspace_root"
echo "Created workspace: $workspace_path"
echo "Created branch: $branch_name (from $base_branch)"
